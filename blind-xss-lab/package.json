{
  "name": "electrostore-demo",
  "version": "1.0.0",
  "description": "ElectroStore demo storefront for presentations and internal demos",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "bot": "node bot.js",
    "init-db": "node scripts/init-db.js",
    "clean": "node scripts/clean-artefacts.js",
    "reset": "npm run clean && npm run init-db",
    "docker:build": "docker build -t electrostore-demo .",
    "docker:run": "docker run -p 3000:3000 electrostore-demo"
  },
  "keywords": [
    "demo",
    "ecommerce",
    "nodejs",
    "express"
  ],
  "author": "ElectroStore Security Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ejs": "^3.1.9",
    "sqlite3": "^5.1.6",
    "bcrypt": "^5.1.1",
    "express-session": "^1.17.3",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
