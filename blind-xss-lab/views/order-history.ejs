<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order History - ElectroStore</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/header', { user: user, cart: cart }) %>

    <main class="main-content">
        <div class="container">
            <% if (typeof message !== 'undefined' && message) { %>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> <%= message %>
                </div>
            <% } %>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-triangle"></i> <%= error %>
                </div>
            <% } %>
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-history"></i> Order History</h1>
                <div>
                    <a href="/products" class="btn btn-secondary">
                        <i class="fas fa-store"></i> Continue Shopping
                    </a>
                </div>
            </div>

            <% if (!orders || orders.length === 0) { %>
                <div class="card">
                    <div class="card-body text-center p-5">
                        <i class="fas fa-clipboard-check fa-3x text-muted mb-3"></i>
                        <h3>No orders yet</h3>
                        <p>You haven't placed any orders yet. Start shopping to create an order.</p>
                        <a href="/products" class="btn btn-primary">
                            <i class="fas fa-store"></i> Browse Products
                        </a>
                    </div>
                </div>
            <% } else { %>
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-clipboard-list"></i> Your Orders
                        </h3>
                    </div>
                    
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Date</th>
                                        <th>Items</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% orders.forEach(order => { %>
                                        <tr>
                                            <td><strong>#<%= order.id %></strong></td>
                                            <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                                            <td><%= order.item_count %> items</td>
                                            <td>$<%= order.total_amount ? order.total_amount.toFixed(2) : '0.00' %></td>
                                            <td>
                                                <span class="status-badge status-<%= order.status.toLowerCase() %>">
                                                    <%= order.status %>
                                                </span>
                                            </td>
                                            <td>
                                                <% if (order.status === 'Created') { %>
                                                    <span class="badge badge-warning">
                                                        <i class="fas fa-clock"></i> Pending Review
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge badge-info">
                                                        <i class="fas fa-check"></i> Reviewed
                                                    </span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            <% } %>

            <style>
            .code-samples {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
                gap: 1rem;
                margin-top: 1rem;
            }

            .code-sample {
                background-color: var(--light-color);
                border-radius: 6px;
                padding: 1rem;
            }

            .code-sample h6 {
                margin-top: 0;
                margin-bottom: 0.5rem;
                color: var(--dark-color);
                font-size: 0.9rem;
            }

            .code-sample pre {
                margin: 0;
                background-color: white;
                padding: 0.5rem;
                border-radius: 4px;
                border: 1px solid var(--border-color);
                font-size: 0.8rem;
                overflow-x: auto;
            }

            .badge {
                padding: 0.25rem 0.5rem;
                border-radius: 4px;
                font-size: 0.75rem;
                font-weight: 600;
            }

            .badge-warning {
                background-color: var(--warning-color);
                color: var(--dark-color);
            }

            .badge-info {
                background-color: var(--info-color);
                color: white;
            }
            </style>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
</body>
</html>