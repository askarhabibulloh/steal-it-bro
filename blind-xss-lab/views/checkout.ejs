<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - ElectroStore</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/header', { user: user, cart: cart }) %>

    <main class="main-content">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-credit-card"></i> Checkout</h1>
                <div>
                    <a href="/cart" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Cart
                    </a>
                </div>
            </div>

            <% if (!cart || cart.length === 0) { %>
                <div class="card">
                    <div class="card-body text-center p-5">
                        <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                        <h3>Your cart is empty</h3>
                        <p>Add some products to your cart before checking out.</p>
                        <a href="/products" class="btn btn-primary">
                            <i class="fas fa-store"></i> Browse Products
                        </a>
                    </div>
                </div>
            <% } else { %>
                <div class="row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                    <!-- Order Summary -->
                    <div>
                        <div class="card mb-4">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <i class="fas fa-shopping-cart"></i> Order Summary
                                </h3>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th>Quantity</th>
                                                <th>Price</th>
                                                <th>Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% cartItems.forEach(item => { %>
                                                <tr>
                                                    <td><%= item.name %></td>
                                                    <td><%= item.quantity %></td>
                                                    <td>$<%= item.price.toFixed(2) %></td>
                                                    <td>$<%= item.itemTotal.toFixed(2) %></td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                                <td><strong>$<%= total.toFixed(2) %></strong></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Checkout Form -->
                    <div>
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <i class="fas fa-truck"></i> Shipping Information
                                </h3>
                            </div>
                            <div class="card-body">
                                <form action="/checkout" method="POST">
                                    <!-- Shipping Address -->
                                    <div class="form-group mb-4">
                                        <label for="address" class="form-label">
                                            <i class="fas fa-map-marker-alt"></i> Shipping Address *
                                        </label>
                                        <textarea 
                                            id="address" 
                                            name="address" 
                                            class="form-control" 
                                            rows="3" 
                                            placeholder="Enter your complete shipping address"
                                            required
                                        ></textarea>
                                        <div class="form-text">
                                            Please provide your full address including street, city, state, and ZIP code.
                                        </div>
                                    </div>

                                    <!-- Delivery Notes -->
                                    <div class="form-group mb-4">
                                        <label for="deliveryNotes" class="form-label">
                                            <i class="fas fa-sticky-note"></i> Delivery Notes
                                        </label>
                                        <textarea 
                                            id="deliveryNotes" 
                                            name="deliveryNotes" 
                                            class="form-control" 
                                            rows="4" 
                                            placeholder="Enter any special delivery instructions"
                                        ></textarea>
                                        <div class="form-text">
                                            Provide any delivery preferences or instructions for the courier.
                                        </div>
                                    </div>

                                    <!-- Security training notice removed for presentation-ready demo -->

                                    <!-- Submit Button -->
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg">
                                            <i class="fas fa-check-circle"></i> Place Order
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- Demo information removed from checkout page -->
                    </div>
                </div>
            <% } %>
        </div>
    </main>
    
    <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
    <script>
    // Auto-focus on address field
    document.addEventListener('DOMContentLoaded', function() {
        const addressField = document.getElementById('address');
        if (addressField) {
            addressField.focus();
        }
    });
    </script>
</body>
</html>