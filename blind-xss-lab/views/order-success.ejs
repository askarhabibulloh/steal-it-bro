<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmed - ElectroStore</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/header', { user: user, cart: cart }) %>

    <main class="main-content">
        <div class="container">
            <div class="text-center p-5">
                <div class="success-icon mb-4">
                    <i class="fas fa-check-circle"></i>
                </div>
                
                <h1 class="mb-3">Order Confirmed!</h1>
                <p class="lead mb-4">Your order has been successfully placed.</p>
                
                <div class="card mb-4 mx-auto" style="max-width: 500px;">
                    <div class="card-body">
                        <h3 class="card-title">
                            <i class="fas fa-receipt"></i> Order Details
                        </h3>
                        <div class="order-info">
                            <p><strong>Order ID:</strong> #<%= orderId %></p>
                            <p><strong>Status:</strong> <span class="status-badge status-created">Created</span></p>
                            <p><strong>Estimated Review:</strong> Within 60 seconds</p>
                        </div>
                    </div>
                </div>

                <!-- Order review and demo notice removed for presentation-ready demo -->

                <div class="d-flex justify-content-center gap-3 mt-4">
                    <a href="/history" class="btn btn-primary">
                        <i class="fas fa-history"></i> View Order History
                    </a>
                    <a href="/products" class="btn btn-secondary">
                        <i class="fas fa-store"></i> Continue Shopping
                    </a>
                </div>

                <!-- Educational purpose note removed from order success page -->
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
    <style>
    .success-icon {
        font-size: 5rem;
        color: var(--success-color);
    }

    .order-info {
        text-align: left;
        padding: 1rem;
        background-color: var(--light-color);
        border-radius: 8px;
    }

    .order-info p {
        margin-bottom: 0.75rem;
        display: flex;
        justify-content: space-between;
    }

    .order-info strong {
        min-width: 120px;
    }
    </style>
</body>
</html>