<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order #<%= order.id %> Details - ElectroStore</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('../partials/header', { user: user, cart: cart }) %>

    <main class="main-content">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>
                    <i class="fas fa-file-invoice"></i> Order #<%= order.id %> Details
                </h1>
                <div>
                    <a href="/admin/dashboard" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>

            <!-- Admin view: order details -->

            <div class="order-details-card">
                <!-- Order Information -->
                <div class="order-info-section">
                    <h3><i class="fas fa-info-circle"></i> Order Information</h3>
                    <div class="row" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
                        <div>
                            <p><strong>Order ID:</strong> #<%= order.id %></p>
                            <p><strong>Customer:</strong> <%= order.customer_name %></p>
                            <p><strong>Order Date:</strong> <%= new Date(order.created_at).toLocaleString() %></p>
                        </div>
                        <div>
                            <p><strong>Status:</strong> 
                                <span class="status-badge status-<%= order.status.toLowerCase() %>">
                                    <%= order.status %>
                                </span>
                            </p>
                            <p><strong>Total Items:</strong> <%= order.items.length %></p>
                            <p><strong>Total Amount:</strong> $<%= order.items.reduce((sum, item) => sum + (item.quantity * item.price_at_time), 0).toFixed(2) %></p>
                        </div>
                    </div>
                </div>

                <!-- Shipping Address (SAFE - escaped output) -->
                <div class="order-info-section">
                    <h3><i class="fas fa-map-marker-alt"></i> Shipping Address</h3>
                    <div class="address-display">
                        <%= order.address %>
                    </div>
                    <p class="text-muted mt-2">
                        <i class="fas fa-check-circle"></i> This field uses <code><%= %></code> (escaped output) - safe from XSS
                    </p>
                </div>

                <!-- DELIVERY NOTES (VULNERABLE - unescaped output) -->
                <div class="order-info-section">
                    <h3>
                        <i class="fas fa-sticky-note"></i> Delivery Notes
                    </h3>
                    <div class="notes-display">
                        <%- order.delivery_notes %>
                    </div>
                </div>

                <!-- Order Items -->
                <div class="order-info-section">
                    <h3><i class="fas fa-shopping-cart"></i> Order Items</h3>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Quantity</th>
                                    <th>Price</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% order.items.forEach(item => { %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="cart-item-image">
                                                    <i class="fas fa-box"></i>
                                                </div>
                                                <div>
                                                    <strong><%= item.product_name %></strong>
                                                </div>
                                            </div>
                                        </td>
                                        <td><%= item.quantity %></td>
                                        <td>$<%= item.price_at_time.toFixed(2) %></td>
                                        <td>$<%= (item.quantity * item.price_at_time).toFixed(2) %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                    <td><strong>$<%= order.items.reduce((sum, item) => sum + (item.quantity * item.price_at_time), 0).toFixed(2) %></strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <!-- Status Update -->
                <div class="order-info-section">
                    <h3><i class="fas fa-cog"></i> Update Status</h3>
                    <div class="d-flex gap-2">
                        <% if (order.status === 'Created') { %>
                            <form action="/admin/order/<%= order.id %>/status" method="POST">
                                <input type="hidden" name="status" value="Processing">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-play"></i> Mark as Processing
                                </button>
                            </form>
                        <% } else if (order.status === 'Processing') { %>
                            <form action="/admin/order/<%= order.id %>/status" method="POST">
                                <input type="hidden" name="status" value="Shipped">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-shipping-fast"></i> Mark as Shipped
                                </button>
                            </form>
                        <% } else { %>
                            <span class="btn btn-secondary" disabled>
                                <i class="fas fa-check"></i> Order Shipped
                            </span>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Educational Information -->
            <div class="card mt-4">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-graduation-cap"></i> XSS Vulnerability Analysis
                    </h3>
                </div>
                <div class="card-body">
                    <h4>Notes</h4>
                    <p>Review delivery notes as entered by customers. For presentations, demonstrations of security topics are coordinated separately.</p>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="/js/main.js"></script>
    <script>
    // This script demonstrates that scripts in delivery notes will execute
    console.log('Order details page loaded. Any XSS payload in delivery notes will execute now.');
    console.log('Delivery notes content:', `<%= order.delivery_notes %>`);
    </script>
</body>
</html>