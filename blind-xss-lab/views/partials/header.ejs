<header class="header">
    <div class="container">
        <nav class="navbar">
            <div class="logo">
                <a href="/">
                    <i class="fas fa-bolt"></i>
                    <span>ElectroStore</span>
                </a>
            </div>
            <ul class="nav-links">
                <% if (user) { %>
                    <li><a href="/products"><i class="fas fa-store"></i> Products</a></li>
                    <li><a href="/cart"><i class="fas fa-shopping-cart"></i> Cart 
                        <% if (cart && cart.length > 0) { %>
                            <span class="cart-count"><%= cart.length %></span>
                        <% } %>
                    </a></li>
                    <li><a href="/history"><i class="fas fa-history"></i> Orders</a></li>
                    <% if (user.isAdmin) { %>
                        <li><a href="/admin/dashboard"><i class="fas fa-user-shield"></i> Admin</a></li>
                    <% } %>
                    <li class="user-menu">
                        <span class="username"><i class="fas fa-user"></i> <%= user.username %></span>
                        <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
                    </li>
                <% } else { %>
                    <li><a href="/login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
                    <li><a href="/signup"><i class="fas fa-user-plus"></i> Sign Up</a></li>
                <% } %>
            </ul>
        </nav>
    </div>
</header>